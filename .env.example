DATABASE_URL=sqlite:////app/data/delivery.sqlite3
SCAN_INPUT_DIR=/scans
WORK_DIR=/app/data/work
WORKER_POLL_INTERVAL_SECONDS=15
ATTACHMENT_POLL_INTERVAL_SECONDS=300
NOTIFICATION_RETRY_INTERVAL_SECONDS=900
DEFAULT_LINK_EXPIRY_DAYS=7
NORMALIZATION_AUTO_ACCEPT_THRESHOLD=0.92

# Metadata resolution
OPENALEX_EMAIL=library@example.edu
CROSSREF_MAILTO=library@example.edu
GBV_SRU_URL=https://sru.k10plus.de/gvk
RESOLUTION_PRIORITY_LOBID=1
RESOLUTION_PRIORITY_GBV=2
RESOLUTION_PRIORITY_CROSSREF=3
RESOLUTION_PRIORITY_OPENALEX=4

# Delivery storage
NEXTCLOUD_BASE_URL=https://nextcloud.example.edu
NEXTCLOUD_USERNAME=service-account
NEXTCLOUD_PASSWORD=change-me
NEXTCLOUD_DAV_BASE_PATH=/remote.php/dav/files/{username}
NEXTCLOUD_ROOT_PATH=/Document-Delivery

# Zotero
ZOTERO_LIBRARY_TYPE=group
ZOTERO_LIBRARY_ID=1234567
ZOTERO_API_KEY=change-me
ZOTERO_COLLECTION_KEY=
ZOTERO_IN_PROCESS_TAG=in process

# Citation rendering for delivery mails
CITATION_STYLE=apa
CITATION_LOCALE_DE=de-DE
CITATION_LOCALE_EN=en-US
CITATION_LOCALE_PL=pl-PL

# FormCycle + operator API
FORMCYCLE_WEBHOOK_SECRET=change-me
CLARIFICATION_FORM_URL_TEMPLATE=https://formcycle.example.com/form/provide/3104/?request_id={request_id_q}&item_id={item_id_q}&token={token_q}&operator_message={operator_message_q}&item_type={item_type_q}&author={author_q}&workTitle={title_q}&container_title={container_title_q}&issued={issued_q}&volume={volume_q}&issue={issue_q}&page={page_q}
CLARIFICATION_TOKEN_SECRET=change-me
CLARIFICATION_TOKEN_TTL_HOURS=168
INTERNAL_API_TOKEN=change-me

# SMTP delivery
SMTP_HOST=smtp.example.edu
SMTP_PORT=587
SMTP_USERNAME=service-account@example.edu
SMTP_PASSWORD=change-me
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=service-account@example.edu
SMTP_FROM_NAME=Universitaetsbibliothek
SMTP_REPLY_TO=

# OCR configuration:
# OCR_MODE=tesseract_overlay enables the native layered OCR pass.
# OCR_TESSERACT_LANG_PACKS is a Docker build-time list of installed Tesseract language packs.
# OCR_LANGUAGE is the runtime fallback language selection for OCR itself.
# OCR_LANGUAGE_MODE=auto samples a few pages with OCR_LANGUAGE_DETECT_SEED and narrows the final OCR bundle.
OCR_TESSERACT_LANG_PACKS=eng deu pol ces slk slv hrv hun ron bul srp mkd ukr rus bel lit lav est fra nld spa por ita cat dan fin swe nor ell
OCR_MODE=tesseract_overlay
OCR_LANGUAGE_MODE=auto
OCR_LANGUAGE=deu+eng+pol
OCR_LANGUAGE_DETECT_SEED=eng+deu+pol+fra
OCR_LANGUAGE_DETECT_PAGES=2
OCR_DPI=300
OCR_POPPLER_PATH=
OCR_TESSERACT_CMD=
OCR_SKIP_IF_TEXT_LAYER=true
OCR_TEXT_LAYER_MIN_CHARS_PER_PAGE=80
OCR_TEXT_LAYER_MIN_PAGE_RATIO=0.5
OCR_TEXT_LAYER_MIN_ALPHA_RATIO=0.6
